# SupraWall Dashboard — Environment Configuration
# Copy this file to .env.local and fill in your values

# ──────────────────────────────────────────
# SupraWall API Server
# ──────────────────────────────────────────
NEXT_PUBLIC_SUPRAWALL_API_URL=http://localhost:3001
SUPRAWALL_API_URL=http://localhost:3001

# ──────────────────────────────────────────
# Firebase (Optional — for authentication & push notifications)
# ──────────────────────────────────────────
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_APP_ID=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

# ──────────────────────────────────────────
# Vault Encryption Key (must match server)
# ──────────────────────────────────────────
# VAULT_ENCRYPTION_KEY=
#
# PRODUCTION NOTE: For production deployments, do NOT store VAULT_ENCRYPTION_KEY
# as a plain environment variable. Use a managed secrets service instead:
#   - AWS KMS / AWS Secrets Manager
#   - GCP Secret Manager
#   - Azure Key Vault
#   - HashiCorp Vault
# Rotate this key immediately if it is ever exposed. All vault secrets must be
# re-encrypted after rotation.
# DATABASE_CA_CERT=          # (optional) PEM-encoded CA certificate for TLS DB connections

# ──────────────────────────────────────────
# Auth Mode: "stealth" (default) or "open"
# ──────────────────────────────────────────
# "stealth" — Registration disabled, only ADMIN_EMAILS can log in (SaaS/cloud)
# "open"    — Anyone can register and log in (self-hosted / open-source)
# NEXT_PUBLIC_AUTH_MODE=open

# ──────────────────────────────────────────
# Admin Access (comma-separated Firebase user emails)
# ──────────────────────────────────────────
# NEXT_PUBLIC_ADMIN_EMAILS=admin@yourdomain.com
# ADMIN_EMAILS=admin@yourdomain.com

# ──────────────────────────────────────────
# Cron Secret (for scheduled tasks)
# Generate with: openssl rand -hex 32
# ──────────────────────────────────────────
# CRON_SECRET=

# ──────────────────────────────────────────
# Google Analytics (Optional)
# ──────────────────────────────────────────
# GA_PROPERTY_ID=

<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <AssemblyName>SupraWall</AssemblyName>
    <RootNamespace>SupraWall</RootNamespace>
    <Version>0.1.0</Version>
    <Authors>SupraWall Contributors</Authors>
    <Description>C# SDK for SupraWall. Policy enforcement for AI agents.</Description>
    <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
    <PackageProjectUrl>https://supra-wall.com</PackageProjectUrl>

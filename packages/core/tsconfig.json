{
    "compilerOptions": {
        "target": "ES2022",
        "module": "CommonJS",
        "lib": ["ES2022", "DOM"],
        "moduleResolution": "node",
        "declaration": true,
        "outDir": "./dist",
        "strict": false,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "types": ["node"]
    },
    "exclude": ["node_modules", "dist", "__tests__"]
}
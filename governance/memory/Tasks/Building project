export async function processApprovalTimeouts() {
  const now = new Date();
  
  // Find all pending approvals that have exceeded timeout
  const timedOutRequests = await db.approvalRequests.findMany({
    where: {
      status: 'pending',
      requested_at: {
        lt: new Date(now.getTime() - 30 * 60 * 1000) // 30 min ago
      }
    }
  });
  
  for (const request of timedOutRequests) {
    // Mark as timeout
    await db.approvalRequests.update(request.id, {
      status: 'timeout',
      responded_at: now
    });
    
    // Notify agent waiting for approval
    await notifyAgentOfTimeout(request.session_id);
    
    // Log audit event
    await logApprovalTimeout(request);
    
    // Notify approvers that request expired
    await notifyApproversOfTimeout(request);
  }
  
  console.log(`Processed ${timedOutRequests.length} approval timeouts`);
}

// Optimization: Cache frequently accessed approval requests
import { Redis } from 'ioredis';

const redis = new Redis(process.env.REDIS_URL);

export async function getApprovalStatus(approvalRequestId: string) {
  // Check cache first
  const cached = await redis.get(`approval:${approvalRequestId}`);
  if (cached) {
    return JSON.parse(cached);
  }
  
  // Fetch from DB
  const request = await db.approvalRequests.findById(approvalRequestId);
  
  // Cache for 5 minutes if still pending, indefinitely if resolved
  const ttl = request.status === 'pending' ? 300 : null;
  await redis.set(
    `approval:${approvalRequestId}`,
    JSON.stringify(request),
    'EX',
    ttl
  );
  
  return request;
}

export class ThreatIntelligenceNetwork {
  /**
   * When ANY customer blocks an action, contribute to shared threat feed
   * (anonymized, privacy-preserving)
   */
  async reportThreat(
    tenantId: string,
    threat: {
      tool_name: string;
      pattern: string;
      severity: 'low' | 'medium' | 'high' | 'critical';
      indicators: string[];
    }
  ) {
    // Hash tenant ID for privacy
    const anonymizedTenantId = hashTenantId(tenantId);
    
    await db.threatIntelligence.create({
      id: generateThreatId(),
      anonymized_tenant_id: anonymizedTenantId,
      tool_name: threat.tool_name,
      pattern_hash: hashPattern(threat.pattern),
      severity: threat.severity,
      indicators: threat.indicators,
      reported_at: new Date(),
      confirmed_count: 1 // First report
    });
  }
  
  /**
   * Check if action matches known threat patterns across network
   */
  async checkAgainstNetwork(
    toolName: string,
    parameters: any
  ): Promise<ThreatMatch | null> {
    // Extract indicators from parameters
    const indicators = this.extractIndicators(toolName, parameters);
    
    // Query threat database
    const threats = await db.threatIntelligence.findMany({
      where: {
        tool_name: toolName,
        indicators: { hasSome: indicators },
        confirmed_count: { gte: 3 }, // Seen by at least 3 customers
        severity: { in: ['high', 'critical'] }
      }
    });
    
    if (threats.length > 0) {
      const topThreat = threats[0];
      
      return {
        matched: true,
        threat_id: topThreat.id,
        severity: topThreat.severity,
        confidence: this.calculateConfidence(topThreat.confirmed_count),
        description: `Known threat pattern seen by ${topThreat.confirmed_count} organizations`,
        recommendation: 'BLOCK'
      };
    }
    
    return null;
  }
  
  private extractIndicators(toolName: string, parameters: any): string[] {
    const indicators: string[] = [];
    
    // Extract URLs
    const urls = this.extractURLs(JSON.stringify(parameters));
    indicators.push(...urls);
    
    // Extract IP addresses
    const ips = this.extractIPs(JSON.stringify(parameters));
    indicators.push(...ips);
    
    // Extract dangerous patterns
    if (toolName === 'bash' || toolName === 'shell') {
      const commands = this.extractCommands(parameters);
      indicators.push(...commands);
    }
    
    return indicators;
  }
  
  private calculateConfidence(confirmedCount: number): number {
    // More confirmations = higher confidence
    return Math.min(confirmedCount / 10, 1.0);
  }
}

// Integrate into policy check
async function checkPolicyWithThreatIntel(request: PolicyCheckRequest) {
  // 1. Normal policy check
  const policyDecision = await checkPolicy(request);
  
  // 2. Check against threat network
  const threatNetwork = new ThreatIntelligenceNetwork();
  const threatMatch = await threatNetwork.checkAgainstNetwork(
    request.tool_name,
    request.tool_parameters
  );
  
  if (threatMatch && threatMatch.severity === 'critical') {
    // Override policy - block known threats
    return {
      decision: 'DENY',
      reason: `Blocked by threat intelligence: ${threatMatch.description}`,
      threat_match: threatMatch,
      source: 'network_intelligence'
    };
  }
  
  // If we blocked it, report to network
  if (policyDecision.decision === 'DENY') {
    await threatNetwork.reportThreat(request.agent_id, {
      tool_name: request.tool_name,
      pattern: JSON.stringify(request.tool_parameters),
      severity: 'medium',
      indicators: threatNetwork.extractIndicators(
        request.tool_name,
        request.tool_parameters
      )
    });
  }
  
  return policyDecision;
}

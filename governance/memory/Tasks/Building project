// src/lib/audit/forensic-logger.ts

import crypto from 'crypto';

export class ForensicAuditLogger {
  private secretKey: string;
  
  constructor() {
    this.secretKey = process.env.AUDIT_LOG_SECRET_KEY!;
  }
  
  async log(event: Partial<ForensicAuditLog>): Promise<ForensicAuditLog> {
    const timestamp = new Date();
    
    // Get previous log hash for chain
    const previousLog = await this.getLatestLogForTenant(event.tenant_id!);
    const previousLogHash = previousLog ? this.hashLog(previousLog) : null;
    
    // Sanitize sensitive data
    const sanitizedParameters = this.sanitizeParameters(event.tool_parameters);
    const parametersHash = this.hashObject(event.tool_parameters);
    
    // Build complete log entry
    const logEntry: ForensicAuditLog = {
      id: this.generateLogId(),
      timestamp,
      server_timestamp: timestamp,
      tenant_id: event.tenant_id!,
      agent_id: event.agent_id!,
      agent_uri: event.agent_uri!,
      parent_agent_id: event.parent_agent_id,
      human_user_id: event.human_user_id,
      session_id: event.session_id!,
      event_type: event.event_type!,
      tool_name: event.tool_name!,
      tool_parameters: sanitizedParameters,
      tool_parameters_hash: parametersHash,
      decision: event.decision!,
      policy_matched: event.policy_matched!,
      policy_version: event.policy_version!,
      decision_reason: event.decision_reason!,
      approval_request_id: event.approval_request_id,
      approver_user_id: event.approver_user_id,
      approver_comment: event.approver_comment,
      execution_context: event.execution_context!,
      compliance_tags: event.compliance_tags || [],
      data_classification: event.data_classification || 'internal',
      retention_policy: this.determineRetentionPolicy(event.compliance_tags || []),
      previous_log_hash: previousLogHash,
      log_signature: '', // Will be set below
      metadata: event.metadata || {}
    };
    
    // Generate cryptographic signature
    logEntry.log_signature = this.signLog(logEntry);
    
    // Write to database (immutable)
    await db.auditLogs.create(logEntry);
    
    // Also write to append-only storage for compliance
    await this.writeToImmutableStorage(logEntry);
    
    return logEntry;
  }
  
  private signLog(log: ForensicAuditLog): string {
    const logString = JSON.stringify({
      id: log.id,
      timestamp: log.timestamp,
      agent_id: log.agent_id,
      event_type: log.event_type,
      tool_name: log.tool_name,
      tool_parameters_hash: log.tool_parameters_hash,
      decision: log.decision,
      previous_log_hash: log.previous_log_hash
    });
    
    return crypto
      .createHmac('sha256', this.secretKey)
      .update(logString)
      .digest('hex');
  }
  
  private hashLog(log: ForensicAuditLog): string {
    return crypto
      .createHash('sha256')
      .update(log.id + log.timestamp + log.log_signature)
      .digest('hex');
  }
  
  private hashObject(obj: any): string {
    return crypto
      .createHash('sha256')
      .update(JSON.stringify(obj))
      .digest('hex');
  }
  
  private sanitizeParameters(params: any): any {
    // Remove sensitive fields
    const sanitized = { ...params };
    const sensitiveFields = ['password', 'api_key', 'token', 'secret', 'ssn', 'credit_card'];
    
    for (const field of sensitiveFields) {
      if (field in sanitized) {
        sanitized[field] = '[REDACTED]';
      }
        }
    }
    
    return sanitized;
  }
  
  private determineRetentionPolicy(complianceTags: string[]): string {
    // SOC2 requires 1 year minimum
    if (complianceTags.includes('SOC2')) return '1_year';
    
    // GDPR requires ability to delete, but keep 90 days for security
    if (complianceTags.includes('GDPR')) return '90_days';
    
    // HIPAA requires 6 years
    if (complianceTags.includes('HIPAA')) return '6_years';
    
    // Default: 1 year
    return '1_year';
  }
  
  private async writeToImmutableStorage(log: ForensicAuditLog) {
    // Write to S3 with object lock enabled (WORM - Write Once Read Many)
    await s3.putObject({
      Bucket: process.env.AUDIT_LOG_BUCKET!,
      Key: `${log.tenant_id}/${log.timestamp.getFullYear()}/${log.id}.json`,
      Body: JSON.stringify(log, null, 2),
      ContentType: 'application/json',
      Metadata: {
        'tenant-id': log.tenant_id,
        'event-type': log.event_type,
        'compliance-tags': log.compliance_tags.join(',')
      },
      // Enable object lock for immutability
      ObjectLockMode: 'COMPLIANCE',
      ObjectLockRetainUntilDate: this.calculateRetentionDate(log.retention_policy)
    });
  }
  
  // Verify log integrity
  async verifyLogIntegrity(logId: string): Promise<boolean> {
    const log = await db.auditLogs.findById(logId);
    if (!log) return false;
    
    // 1. Verify signature
    const expectedSignature = this.signLog(log);
    if (log.log_signature !== expectedSignature) {
      console.error(`Log ${logId} signature mismatch!`);
      return false;
    }
    
    // 2. Verify chain (if has previous log)
    if (log.previous_log_hash) {
      const previousLog = await this.getPreviousLog(log);
      if (previousLog) {
        const expectedPreviousHash = this.hashLog(previousLog);
        if (log.previous_log_hash !== expectedPreviousHash) {
          console.error(`Log ${logId} chain broken!`);
          return false;
        }
      }
    }
    
    // 3. Verify parameters hash
    const actualParametersHash = this.hashObject(log.tool_parameters);
    if (log.tool_parameters_hash !== actualParametersHash) {
      console.error(`Log ${logId} parameters tampered!`);
      return false;
    }
    
    return true;
  }
  
  // Verify entire chain for tenant
  async verifyTenantAuditChain(tenantId: string): Promise<{
    valid: boolean;
    totalLogs: number;
    invalidLogs: string[];
  }> {
    const logs = await db.auditLogs.findMany({
      where: { tenant_id: tenantId },
      orderBy: { timestamp: 'asc' }
    });
    
    const invalidLogs: string[] = [];
    
    for (const log of logs) {
      const valid = await this.verifyLogIntegrity(log.id);
      if (!valid) {
        invalidLogs.push(log.id);
      }
    }
    
    return {
      valid: invalidLogs.length === 0,
      totalLogs: logs.length,
      invalidLogs
    };
  }
}

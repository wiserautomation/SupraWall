# agentgate/policy_client.py

class PolicyDecision:
    def __init__(self, decision_data):
        self.decision = decision_data['decision']
        self.reason = decision_data.get('reason')
        self.approval_request_id = decision_data.get('approval_request_id')
        self._client = None
        
    @property
    def allowed(self):
        return self.decision == 'ALLOW'
    
    @property
    def requires_approval(self):
        return self.decision == 'REQUIRE_APPROVAL'
    
    def wait_for_approval(self, timeout_seconds=1800, poll_interval=5):
        """
        Wait for human approval. Blocks until approved/denied or timeout.
        
        Args:
            timeout_seconds: Max time to wait (default 30 min)
            poll_interval: How often to check (default 5 seconds)
        """
        if not self.requires_approval:
            raise ValueError("Decision doesn't require approval")
        
        start_time = time.time()
        
        while True:
            # Check if we've exceeded timeout
            if time.time() - start_time > timeout_seconds:
                raise ApprovalTimeout(f"No approval received within {timeout_seconds}s")
            
            # Poll approval status
            status = self._client._get_approval_status(self.approval_request_id)
            
            if status['status'] == 'approved':
                return ApprovalResponse(
                    approved=True,
                    approved_by=status['response_by'],
                    comment=status.get('comment')
                )
            elif status['status'] == 'denied':
                return ApprovalResponse(
                    approved=False,
                    denied_by=status['response_by'],
                    comment=status.get('comment')
                )
            elif status['status'] == 'timeout':
                raise ApprovalTimeout("Approval request timed out on server")
            
            # Still pending, wait before polling again
            time.sleep(poll_interval)

class ApprovalResponse:
    def __init__(self, approved, approved_by=None, denied_by=None, comment=None):
        self.approved = approved
        self.approved_by = approved_by
        self.denied_by = denied_by
        self.comment = comment

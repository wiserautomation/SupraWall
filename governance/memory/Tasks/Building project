// src/api/approvals/respond.ts

export async function respondToApproval(
  approvalRequestId: string,
  userId: string,
  decision: "approved" | "denied",
  comment?: string
): Promise<ApprovalResponse> {
  
  const request = await db.approvalRequests.findById(approvalRequestId);
  
  // Verify user is authorized approver
  if (!request.approvers.includes(userId)) {
    throw new Error("User not authorized to approve this request");
  }
  
  // Check if already responded
  if (request.status !== "pending") {
    throw new Error(`Request already ${request.status}`);
  }
  
  // Update approval request
  await db.approvalRequests.update(approvalRequestId, {
    status: decision === "approved" ? "approved" : "denied",
    responded_at: new Date(),
    response_by: userId
  });
  
  // Create response record
  const response = await db.approvalResponses.create({
    approval_request_id: approvalRequestId,
    decision,
    decided_by: userId,
    decided_at: new Date(),
    comment
  });
  
  // Log to audit trail
  await logApprovalDecision(request, response);
  
  // Notify agent that approval is ready
  await notifyAgentOfDecision(request.session_id, decision);
  
  return response;
}

// src/api/agents/register.ts

import { db } from '@/lib/database';
import { generateAgentId, generateApiKey, generateAgentURI } from '@/lib/identity';

export async function POST(request: Request) {
  const { name, tenant_id, scopes, scope_limits, parent_agent_id } = await request.json();
  
  // Validate tenant access
  const tenant = await db.tenants.findById(tenant_id);
  if (!tenant) throw new Error("Tenant not found");
  
  // Generate identity
  const agent_id = generateAgentId();
  const api_key = generateApiKey(agent_id, tenant_id);
  const agent_uri = generateAgentURI(name, tenant_id);
  
  // Validate scopes against tenant permissions
  const allowedScopes = await validateScopes(tenant_id, scopes);
  
  // Create agent record
  const agent = await db.agents.create({
    id: agent_id,
    name,
    tenant_id,
    agent_uri,
    api_key: hashApiKey(api_key), // Store hashed
    scopes: allowedScopes,
    scope_limits,
    parent_agent_id,
    status: "active",
    created_at: new Date(),
    created_by: request.user.id
  });
  
  return Response.json({
    agent_id,
    agent_uri,
    api_key, // Return plaintext ONCE, never again
    scopes: allowedScopes
  });
}

export class ComplianceMonitor {
  // Run daily compliance checks
  async runDailyChecks(tenantId: string) {
    const today = new Date();
    const results = [];
    
    // Check 1: All agents have minimal necessary scopes
    const overPrivilegedAgents = await this.checkMinimalPrivilege(tenantId);
    if (overPrivilegedAgents.length > 0) {
      results.push({
        check: 'Principle of Least Privilege',
        status: 'FAIL',
        severity: 'HIGH',
        finding: `${overPrivilegedAgents.length} agents have excessive permissions`,
        remediation: 'Review and reduce agent scopes to minimum required',
        agents: overPrivilegedAgents
      });
    }
    
    // Check 2: All high-risk actions have approval workflows
    const highRiskWithoutApproval = await this.checkHighRiskApprovals(tenantId);
    if (highRiskWithoutApproval.length > 0) {
      results.push({
        check: 'High-Risk Action Controls',
        status: 'FAIL',
        severity: 'CRITICAL',
        finding: `${highRiskWithoutApproval.length} high-risk tools lack approval requirements`,
        remediation: 'Configure approval workflows for all high-risk actions'
      });
    }
    
    // Check 3: Audit log integrity
    const integrityCheck = await this.verifyAuditLogIntegrity(tenantId);
    if (!integrityCheck.valid) {
      results.push({
        check: 'Audit Log Integrity',
        status: 'FAIL',
        severity: 'CRITICAL',
        finding: `${integrityCheck.invalidLogs.length} audit logs failed integrity check`,
        remediation: 'Investigate potential tampering immediately',
        invalid_logs: integrityCheck.invalidLogs
      });
    }
    
    // Check 4: Inactive agents with active credentials
    const staleAgents = await this.checkStaleAgents(tenantId, 90); // 90 days
    if (staleAgents.length > 0) {
      results.push({
        check: 'Credential Lifecycle Management',
        status: 'FAIL',
        severity: 
                severity: 'MEDIUM',
        finding: `${staleAgents.length} agents inactive for 90+ days still have active credentials`,
        remediation: 'Revoke or suspend inactive agent credentials',
        agents: staleAgents
      });
    }
    
    // Check 5: Approval timeout compliance
    const approvalMetrics = await this.checkApprovalResponseTimes(tenantId);
    if (approvalMetrics.avgResponseTime > 15 * 60 * 1000) { // 15 minutes
      results.push({
        check: 'Approval Response Times',
        status: 'WARNING',
        severity: 'LOW',
        finding: `Average approval response time: ${approvalMetrics.avgResponseTime / 60000} minutes`,
        remediation: 'Review approver availability and notification settings'
      });
    }
    
    // Check 6: Failed authentication attempts
    const failedAuthAttempts = await this.checkFailedAuthentications(tenantId);
    if (failedAuthAttempts > 100) {
      results.push({
        check: 'Authentication Security',
        status: 'FAIL',
        severity: 'HIGH',
        finding: `${failedAuthAttempts} failed authentication attempts in last 24h`,
        remediation: 'Investigate potential credential compromise'
      });
    }
    
    // Store compliance check results
    await db.complianceChecks.create({
      tenant_id: tenantId,
      check_date: today,
      results,
      overall_status: results.some(r => r.status === 'FAIL') ? 'NON_COMPLIANT' : 'COMPLIANT'
    });
    
    // Send alerts for critical findings
    const criticalFindings = results.filter(r => r.severity === 'CRITICAL');
    if (criticalFindings.length > 0) {
      await this.sendComplianceAlert(tenantId, criticalFindings);
    }
    
    return results;
  }
  
  private async checkMinimalPrivilege(tenantId: string) {
    const agents = await db.agents.findMany({
      where: { tenant_id: tenantId, status: 'active' },
      include: { 
        scopes: true,
        auditLogs: {
          where: {
            timestamp: { gte: subDays(new Date(), 30) }
          }
        }
      }
    });
    
    return agents.filter(agent => {
      // Get scopes actually used in last 30 days
      const usedScopes = new Set(
        agent.auditLogs.map(log => this.mapToolToScope(log.tool_name))
      );
      
      // Find granted scopes that were never used
      const unusedScopes = agent.scopes.filter(
        scope => !usedScopes.has(scope)
      );
      
      // Flag if > 30% of scopes are unused
      return unusedScopes.length / agent.scopes.length > 0.3;
    });
  }
  
  private async checkHighRiskApprovals(tenantId: string) {
    const highRiskScopes = [
      'database:delete',
      'payment:process',
      'user:delete',
      'admin:*'
    ];
    
    const policies = await db.policies.findMany({
      where: {
        tenant_id: tenantId,
        tool_name: { in: highRiskScopes }
      }
    });
    
    return highRiskScopes.filter(scope => {
      const policy = policies.find(p => p.tool_name === scope);
      return !policy || policy.rule_type !== 'REQUIRE_APPROVAL';
    });
  }
  
  private async verifyAuditLogIntegrity(tenantId: string) {
    const logger = new ForensicAuditLogger();
    return await logger.verifyTenantAuditChain(tenantId);
  }
  
  private async checkStaleAgents(tenantId: string, daysInactive: number) {
    const cutoffDate = subDays(new Date(), daysInactive);
    
    return await db.agents.findMany({
      where: {
        tenant_id: tenantId,
        status: 'active',
        OR: [
          { last_active: { lt: cutoffDate } },
          { last_active: null }
        ]
      }
    });
  }
  
  private async sendComplianceAlert(tenantId: string, findings: any[]) {
    const admins = await db.users.findMany({
      where: { tenant_id: tenantId, role: 'admin' }
    });
    
    for (const admin of admins) {
      await sendEmail({
        to: admin.email,
        subject: '🚨 Critical Compliance Issues Detected',
        template: 'compliance-alert',
        data: { findings }
      });
    }
  }
}

// src/lib/policy-engine.ts

interface PolicyCheckRequest {
  agent_id: string;           // WHO is acting
  agent_api_key: string;      // Authenticate the agent
  tool_name: string;          // WHAT action
  tool_parameters: any;       // WITH what parameters
  session_id?: string;        // WHICH execution context
  parent_agent_id?: string;   // IF delegated, by whom
}

export async function checkPolicy(request: PolicyCheckRequest): Promise<PolicyDecision> {
  // 1. Authenticate agent
  const agent = await authenticateAgent(request.agent_id, request.agent_api_key);
  if (!agent) {
    return { decision: "DENY", reason: "Invalid agent credentials" };
  }
  
  if (agent.status !== "active") {
    return { decision: "DENY", reason: `Agent status: ${agent.status}` };
  }
  
  // 2. Check if agent has required scope
  const requiredScope = mapToolToScope(request.tool_name);
  if (!agent.scopes.includes(requiredScope)) {
    return { 
      decision: "DENY", 
      reason: `Agent lacks scope: ${requiredScope}`,
      required_scope: requiredScope,
      agent_scopes: agent.scopes
    };
  }
  
  // 3. Check scope limits
  const scopeLimit = agent.scope_limits[requiredScope];
  if (scopeLimit) {
    const withinLimits = checkScopeLimits(scopeLimit, request.tool_parameters);
    if (!withinLimits.allowed) {
      // Check if should escalate to approval
      if (withinLimits.requires_approval) {
        return {
          decision: "REQUIRE_APPROVAL",
          reason: withinLimits.reason,
          approval_request: createApprovalRequest(agent, request)
        };
      }
      return { decision: "DENY", reason: withinLimits.reason };
    }
  }
  
  // 4. Check tenant-level policies
  const tenantPolicy = await getTenantPolicy(agent.tenant_id, request.tool_name);
  const policyDecision = evaluatePolicy(tenantPolicy, request);
  
  // 5. Log decision
  await logPolicyDecision({
    agent_id: agent.id,
    agent_uri: agent.agent_uri,
    session_id: request.session_id,
    tool_name: request.tool_name,
    decision: policyDecision.decision,
    timestamp: new Date()
  });
  
  return policyDecision;
}

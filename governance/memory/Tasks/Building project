export async function POST(request: Request) {
  const { tenant_id, filters, date_range, export_format } = await request.json();
  
  // Build query
  const query: any = { tenant_id };
  
  if (filters.agent_ids?.length) {
    query.agent_id = { in: filters.agent_ids };
  }
  
  if (filters.event_types?.length) {
    query.event_type = { in: filters.event_types };
  }
  
  if (filters.decisions?.length) {
    query.decision = { in: filters.decisions };
  }
  
  if (filters.tool_names?.length) {
    query.tool_name = { in: filters.tool_names };
  }
  
  if (date_range) {
    query.timestamp = {
      gte: new Date(date_range.start),
      lte: new Date(date_range.end)
    };
  }
  
  // Execute query
  const logs = await db.auditLogs.findMany({
    where: query,
    orderBy: { timestamp: 'desc' },
    take: 10000 // Max 10K results
  });
  
  // Export in requested format
  if (export_format === 'csv') {
    const csv = convertToCSV(logs);
    return new Response(csv, {
      headers: {
        'Content-Type': 'text/csv',
        'Content-Disposition': `attachment; filename="audit-logs-${Date.now()}.csv"`
      }
    });
  } else if (export_format === 'json') {
    return Response.json(logs);
  } else if (export_format === 'pdf') {
    const pdf = await generateAuditPDF(logs);
    return new Response(pdf, {
      headers: {
        'Content-Type': 'application/pdf',
        'Content-Disposition': `attachment; filename="audit-report-${Date.now()}.pdf"`
      }
    });
  }
  
  return Response.json(logs);
}

// CSV export utility
function convertToCSV(logs: ForensicAuditLog[]): string {
  const headers = [
    'Timestamp',
    'Agent URI',
    'Event Type',
    'Tool Name',
    'Decision',
    'Decision Reason',
    'Approver',
    'Compliance Tags'
  ];
  
  const rows = logs.map(log => [
    log.timestamp.toISOString(),
    log.agent_uri,
    log.event_type,
    log.tool_name,
    log.decision,
    log.decision_reason,
    log.approver_user_id || 'N/A',
    log.compliance_tags.join('; ')
  ]);
  
  return [
    headers.join(','),
    ...rows.map(row => row.map(cell => `"${cell}"`).join(','))
  ].join('\n');
}

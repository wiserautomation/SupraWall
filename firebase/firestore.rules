rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Admin check function
    function isAdmin() {
      return request.auth != null && request.auth.token.email == "peghin@gmail.com";
    }

    // ── Users ────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // ── Agents ───────────────────────────────────────────────────────────
    match /agents/{agentId} {
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if request.auth != null && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ── Policies ─────────────────────────────────────────────────────────
    match /policies/{policyId} {
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if request.auth != null && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ── Audit Logs ───────────────────────────────────────────────────────
    match /audit_logs/{logId} {
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if false; // Cloud Functions only or Agent writes
    }

    // ── Existing: single-tenant API keys ────────────────────────────────
    match /api_keys/{keyId} {
      allow read, write: if false; // Cloud Functions only
    }

    // ── Connect: platforms ───────────────────────────────────────────────
    match /platforms/{platformId} {
      allow read: if request.auth != null
        && resource.data.ownerId == request.auth.uid;
      allow write: if false; // Cloud Functions only

      match /base_policies/{policyId} {
        allow read: if request.auth != null
          && get(/databases/$(database)/documents/platforms/$(platformId))
             .data.ownerId == request.auth.uid;
        allow write: if false; // Cloud Functions only
      }
    }

    // ── Connect: sub-keys ────────────────────────────────────────────────
    match /connect_keys/{subKeyId} {
      allow read, write: if false; // Cloud Functions only
    }

    // ── Connect: audit events ────────────────────────────────────────────
    match /connect_events/{eventId} {
      allow read, write: if false; // Cloud Functions only
    }

    // ── Rate limit counters (internal only) ──────────────────────────────
    match /rate_limit_counters/{counterId} {
      allow read, write: if false; // Cloud Functions only
    }
  }
}

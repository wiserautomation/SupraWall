rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Function to check if a user is logged in
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Function to check if the user is the owner
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    match /agents/{agentId} {
      // User can read, create, update, delete their own agents
      allow read, write: if isOwner(resource.data.userId) || isOwner(request.resource.data.userId);
    }

    match /policies/{policyId} {
      // User can read/write policies if they own the associated agent
      // Note: In a production environment, doing a `get` to verify agent ownership
      // is ideal. For the MVP, we assume the dashboard enforces the correct agentId
      // and checking if `request.auth.uid` matches the agent's userId.
      allow read, write: if isAuthenticated() && 
        get(/databases/$(database)/documents/agents/$(resource.data.agentId != null ? resource.data.agentId : request.resource.data.agentId)).data.userId == request.auth.uid;
    }

    match /audit_logs/{logId} {
      // Users can only read audit logs for their agents
      allow read: if isAuthenticated() &&
        get(/databases/$(database)/documents/agents/$(resource.data.agentId)).data.userId == request.auth.uid;
      // Writing is purely handled by Cloud Functions, thus `allow write: if false;`
      // Server APIs bypass these rules
      allow write: if false;
    }
  }
}

{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"],
      "env": [
        "DATABASE_URL",
        "DATABASE_URL_UNPOOLED",
        "POSTGRES_URL",
        "POSTGRES_URL_NON_POOLING",
        "POSTGRES_USER",
        "POSTGRES_HOST",
        "POSTGRES_PASSWORD",
        "POSTGRES_DATABASE",
        "PGHOST",
        "PGUSER",
        "PGPASSWORD",
        "PGDATABASE",
        "NEON_PROJECT_ID",
        "NEXT_PUBLIC_SUPRAWALL_API_URL",
        "VAULT_ENCRYPTION_KEY",
        "PGHOST_UNPOOLED",
        "POSTGRES_URL_NO_SSL",
        "POSTGRES_PRISMA_URL",
        "NPM_CONFIG_LEGACY_PEER_DEPS",
        "CRON_SECRET",
        "SUPRAWALL_API_URL",
        "TEST_VAR",
        "MAILERLITE_API_KEY"
      ]
    },
    "lint": {
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["build"]
    }
  }
}

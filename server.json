{
  "name": "io.github.wiserautomation/suprawall-mcp",
  "displayName": "SupraWall - EU AI Act Compliance Middleware",
  "version": "1.0.0",
  "description": "EU AI Act compliance middleware for Claude agents with human oversight.",
  "repository": {
    "source": "github",
    "url": "https://github.com/wiserautomation/suprawall-mcp"
  },
  "author": "Wiser Automation",
  "license": "MIT",
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "packages": [
    {
      "registryType": "stdio",
      "identifier": "io.github.wiserautomation/suprawall-mcp",
      "version": "1.0.0",
      "transport": {
        "type": "stdio"
      },
      "packageArguments": [],
      "environmentVariables": []
    }
  ],
  "tools": [
    {
      "name": "check_policy",
      "description": "Check if an AI action complies with configured compliance policies",
      "inputSchema": {
        "type": "object",
        "properties": {
          "action": {
            "type": "string",
            "description": "The action to evaluate for compliance"
          },
          "context": {
            "type": "object",
            "description": "Additional context about the action"
          }
        },
        "required": ["action"]
      },
      "readOnlyHint": true
    },
    {
      "name": "request_approval",
      "description": "Request human approval for a potentially sensitive action",
      "inputSchema": {
        "type": "object",
        "properties": {
          "action": {
            "type": "string",
            "description": "The action requesting approval"
          },
          "reason": {
            "type": "string",
            "description": "Why human approval is needed"
          },
          "urgency": {
            "type": "string",
            "enum": ["low", "medium", "high"],
            "description": "Urgency level for approval"
          }
        },
        "required": ["action", "reason"]
      },
      "readOnlyHint": true
    }
  ],
  "io.modelcontextprotocol.registry/publisher-provided": {
    "capabilities": [
      "EU AI Act Article 14 compliance",
      "Human-in-the-loop oversight",
      "Tamper-evident audit logging",
      "Policy-based risk management"
    ],
    "industry": "Compliance & Governance",
    "useCases": [
      "Healthcare AI agents",
      "Financial services compliance",
      "Government AI systems",
      "Regulated industry automation"
    ],
    "privacyPolicy": "https://www.supra-wall.com/privacy",
    "documentation": "https://www.supra-wall.com/docs",
    "supportEmail": "support@wiserautomation.agency"
  }
}

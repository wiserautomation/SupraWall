# SupraWall — Root Environment Configuration
# Copy this file to .env.local and fill in your values

# ──────────────────────────────────────────
# SupraWall API Server
# ──────────────────────────────────────────
NEXT_PUBLIC_SUPRAWALL_API_URL=http://localhost:3001
SUPRAWALL_API_URL=http://localhost:3001

# ──────────────────────────────────────────
# Firebase (Optional)
# ──────────────────────────────────────────
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_APP_ID=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=

# ──────────────────────────────────────────
# Google Analytics (Optional)
# ──────────────────────────────────────────
# GA_PROPERTY_ID=

# ──────────────────────────────────────────
# Stripe Billing (Proprietary Cloud Integration)
# ──────────────────────────────────────────
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_STARTER_PRICE_ID=
# STRIPE_TEAM_PRICE_ID=
# STRIPE_BUSINESS_PRICE_ID=
# STRIPE_METERED_PRICE_ID=

# ──────────────────────────────────────────
# Vault
# ──────────────────────────────────────────
# VAULT_ENCRYPTION_KEY=
# Generate with: openssl rand -hex 32
# PRODUCTION NOTE: Use a managed secrets service (AWS KMS, GCP Secret Manager,
# HashiCorp Vault) instead of a plain env var. Rotate immediately if exposed.

# Database TLS (optional custom CA for self-hosted Postgres)
# DATABASE_CA_CERT=    # PEM-encoded CA certificate

# ──────────────────────────────────────────
# Layer 2: AI Semantic Analysis (Growth+ tiers)
# ──────────────────────────────────────────
# SUPRAWALL_SEMANTIC_LLM_KEY=sk-your-openai-key-here
# SUPRAWALL_SEMANTIC_MODEL=gpt-4o-mini
# SUPRAWALL_SEMANTIC_TIMEOUT_MS=300

# Thresholds (0.0–1.0) — tune sensitivity without code changes
# SUPRAWALL_DENY_THRESHOLD=0.85
# SUPRAWALL_APPROVAL_THRESHOLD=0.60
# SUPRAWALL_FLAG_THRESHOLD=0.35

# Admin Access
# ADMIN_EMAILS=peghin@gmail.com
# NEXT_PUBLIC_ADMIN_EMAILS=peghin@gmail.com

# ──────────────────────────────────────────
# AWS Marketplace Integration
# ──────────────────────────────────────────
# AWS_MARKETPLACE_PRODUCT_CODE=         # From AMMP → Product detail page
# AWS_MARKETPLACE_SNS_TOPIC_ARN=        # From AMMP → SNS configuration
# AWS_MARKETPLACE_REDIRECT_URL=https://www.supra-wall.com/onboarding
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=                    # IAM user with marketplace:ResolveCustomer permission
# AWS_SECRET_ACCESS_KEY=

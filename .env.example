# SupraWall — Root Environment Configuration
# Copy this file to .env.local and fill in your values

# ──────────────────────────────────────────
# SupraWall API Server
# ──────────────────────────────────────────
# Point your SDKs to this URL
NEXT_PUBLIC_SUPRAWALL_API_URL=http://localhost:3001
SUPRAWALL_API_URL=http://localhost:3001

# ──────────────────────────────────────────
# Database (PostgreSQL)
# ──────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/suprawall

# ──────────────────────────────────────────
# Vault (Encryption)
# ──────────────────────────────────────────
# Key used to encrypt vault secrets at rest in the database.
# Generate with: openssl rand -hex 32
VAULT_ENCRYPTION_KEY=

# ──────────────────────────────────────────
# Layer 2: AI Semantic Analysis (Optional)
# ──────────────────────────────────────────
# Enable high-tier AI guardrails by providing an OpenAI-compatible key.
# SUPRAWALL_SEMANTIC_LLM_KEY=sk-your-openai-key-here
# SUPRAWALL_SEMANTIC_MODEL=gpt-4o-mini

# Thresholds (0.0–1.0)
# SUPRAWALL_DENY_THRESHOLD=0.85
# SUPRAWALL_APPROVAL_THRESHOLD=0.60

# ──────────────────────────────────────────
# Observability & Notifications
# ──────────────────────────────────────────
# LOG_LEVEL=info
# SLACK_WEBHOOK_URL=
